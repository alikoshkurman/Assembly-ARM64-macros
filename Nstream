    mov x21, x0
    mov x20, x0
read_loop\@:
    add x0, x20, #4096
    mov x8, #214
    svc #0
    cmp x0, x20
    beq mem_error\@
    mov x20, x0
    mov x0, x19
    sub x1, x20, #4096     
