    stp x2, x8, [sp, #-32]!
    push1 x13
    load.reg x13, \name
    mov x0, x13
    .ifc \need, no
        mov x1, #0
        mov x2, #0
    .else
        .ifc \need, yes
            .pushsection .bss
            .local\@: .skip 16
            .local_len\@: .word 16
            .popsection
            adrp x1, .local\@
            add x1, x1, :lo12:.local\@
            adrp x2, .local_len\@
            add x2, x2, :lo12:.local_len\@
        .else
            .error "Unknown argument \need"
        .endif
    .endif
    mov x8, #202
    svc #0
    save.reg x0, \client_name
    pop1 x13
    ldp x8, x2, [sp], #32
    ldp x1, x0, [sp], #32
.endm

