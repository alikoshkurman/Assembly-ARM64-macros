.macro net.sawc txt, name, head="HTTP/1.1 200 OK\r\nContent-Type: text/html; charset=utf-8\r\nConnection: close\r\n\r\n"
while true
    net.acpt \name, __client\@
    net.write "\head\txt", __client\@
    net.close __client\@
while.end
.endm

.macro net.read name, reg_addr, reg_len

    str x19, [sp, #-32]!
    stp x20, x21, [sp, #8]
    str x22, [sp, #24]

    load.reg x19, \name
    mov x22, #0              
