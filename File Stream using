.section .text
.global _start

_start:
    print "Текст"

    trunc.file "Название_файла" удалит содержимое файла
    file.open x10, "Название_файла", права, #(ar | aw | ax | gr | gw | otr) /* у нас есть права write, trunc, read, append, creat их можно комбинировать типо write | trunc он очистит файл и даст записать туда некую строку
    также у нас есть ar это значит что у админа есть доступ для прочтения, а также есть w, r, x w значит запись, r читать, x права запускать тоесть есть a = админ, g = твоя команда, ot = остальные неизвестные люди,
    также можно записать в образе числа типо x = 1, w = 2, r = 4 теперь начинаем с #0 и затем если мы всем хотим дать запись то #0222 если всем читать и запуск то #0666 первая линия с цифрой 6 это для администратора, 2 для группы, 3 для остальных.
    */ 
    file.write "Hello", x10 // x10 это десериптор который мы передали в file.open, эта команда будет работать если дать права записи тоесть file.open x10, "название_файла", write | creat, #0760 кстати если файла нет и есть флаг creat он создастся и кстати #0760 значит что админу все права группе только хаись и чтение а остальным нечего
    file.read x10, var, сколько_байт_прочитать, x3 // в var будет прочитанный текст а в x3 будет сколько байт прочитали кстати нельзя использовать x0, x1, x2, x8 регистры.
    file.close x10 // закроет файл чтобы не занимать место в памяти

    file.remove "Название_файла" // удалит полностью файл
    exit 0 // выход с кодом 0
